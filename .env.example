# State Store (PostgreSQL)
POSTGRES_DB=seeddb
POSTGRES_USER=seed
POSTGRES_PASSWORD=seed

# Core MCP
CORE_MCP_OPA_URL=http://opa:8181
CORE_MCP_DATABASE_URL=postgresql://seed:seed@state-store:5432/seeddb
CORE_MCP_LOG_LEVEL=INFO
CORE_MCP_HOST=0.0.0.0
CORE_MCP_PORT=8000

# GCP Organization (required for project creation and SA hierarchy)
CORE_MCP_SEED_PROJECT_ID=
CORE_MCP_SEED_PROJECT_NUMBER=
CORE_MCP_ORG_ID=

# GitHub owner/org allowed to deploy via WIF (e.g. Gianlucaboni)
CORE_MCP_GITHUB_OWNER=
